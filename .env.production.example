# Production environment — copy this to .env.production on the server and fill in values.
# Never commit .env.production to git.

DATABASE_URL=postgres://sidetrack:your_password@db:5432/sidetrack
POSTGRES_PASSWORD=your_password

APP_URL=https://sidetrackmusic.nl

# Cloudflare Tunnel — required for production HTTPS via sidetrackmusic.nl
CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare maintenance page toggle — optional, only needed if you have a Worker set up
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKER_NAME=sidetrack-maintenance
