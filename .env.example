# Production environment — copy this to .env.production on the server and fill in values.
# Never commit .env.production to git.

DATABASE_URL=db_url
POSTGRES_PASSWORD=your_password

# Postcode autofill — free key from https://postcode.tech
POSTCODE_API_KEY=

APP_URL=https://url.com

# Cloudflare Tunnel — required for production HTTPS via example.nl
CLOUDFLARE_TUNNEL_TOKEN=

# Cloudflare maintenance page toggle — optional, only needed if you have a Worker set up
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKER_NAME=worker_name

# Email — Resend (https://resend.com, free tier: 3000/month)
# Verify example.nl in the Resend dashboard to unlock custom from address
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@example.nl
NOTIFICATION_EMAIL=example@gmail.com